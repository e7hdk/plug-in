{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "f=\"${CLAUDE_PROJECT_DIR}/${user_config.verify_command}\"; if [ -x \"$f\" ]; then bash \"$f\"; fi"
          }
        ]
      }
    ]
  }
}
